# ===========================================
# 课伴 (KeBan) 服务端环境变量模板
# ===========================================
# 复制此文件为 .env 并填入实际值
# 生产环境复制为 .env.production 并通过安全渠道注入真实凭证
# 切勿将含有真实密钥的 .env / .env.production 提交到 Git

# --- 应用环境 ---
# 可选值：development / production
APP_ENV=development

# --- 数据库配置 ---
# DB_USER: PostgreSQL 用户名
DB_USER=keban
# DB_PASSWORD: PostgreSQL 密码（生产环境使用强随机密码，如 openssl rand -base64 32）
DB_PASSWORD=keban_dev
# DB_NAME: 数据库名称
DB_NAME=keban
# DATABASE_URL: 完整连接字符串（可选，优先级高于上面的分离配置）
DATABASE_URL=postgresql://keban:keban_dev@localhost:5432/keban

# --- Redis 配置 ---
# REDIS_PASSWORD: Redis 认证密码（本地开发可留空，生产环境必须设置）
REDIS_PASSWORD=
# REDIS_URL: Redis 连接地址
REDIS_URL=redis://localhost:6379

# --- JWT 安全密钥 ---
# 生成方法: openssl rand -hex 32
# 生产环境必须替换为随机字符串
JWT_SECRET=change-this-to-a-random-string-in-production

# --- AI 模型 API Key ---
# 通义千问：https://dashscope.aliyun.com
QWEN_API_KEY=
# DeepSeek：https://platform.deepseek.com
DEEPSEEK_API_KEY=
# 智谱 GLM：https://open.bigmodel.cn
GLM_API_KEY=
# Gemini（可选，用于视频分析）：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Supabase 配置 ---
# 从 Supabase Dashboard > Settings > API > JWT Settings 获取 JWT Signing Secret
SUPABASE_JWT_SECRET=
# 项目 URL：从 Supabase Dashboard > Settings > API 获取
SUPABASE_URL=https://your-project-id.supabase.co
# JWKS URL：通常为 <SUPABASE_URL>/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json

# --- 服务端口 ---
SYNC_SERVICE_PORT=8080
AI_GATEWAY_PORT=8000

# --- CORS 允许的域名（多个用逗号分隔）---
CORS_ORIGINS=http://localhost:5173
